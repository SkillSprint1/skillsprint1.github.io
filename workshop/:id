const parts = window.location.pathname.split("/");
const workshopId = parts[parts.length - 1];

const deepLink = `skillsprint://workshop/${workshopId}`;

let openedAt = Date.now();

window.location.href = deepLink;

setTimeout(() => {
  const timeElapsed = Date.now() - openedAt;

  // If still on page after delay → assume app did not open
  if (timeElapsed < 2000 && !document.hidden) {
    window.location.href =
      "https://play.google.com/store/apps/details?id=com.futuristixapps.skillsprint";
  }
}, 1800);
