<script>
  const parts = window.location.pathname.split("/");
  const workshopId = parts[parts.length - 1];

  const deepLink = `skillsprint://workshop/${workshopId}`;

  window.location.href = deepLink;

  setTimeout(() => {
    if (!document.hidden) {
      window.location.href =
        "https://play.google.com/store/apps/details?id=com.skillsprint.app";
    }
  }, 1500);
</script>
